generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String           @unique
  phone                String           @unique
  passwordHash         String
  role                 UserRole
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  createdAnnouncements Announcement[]   @relation("AnnouncementCreator")
  csMessages           CSMessage[]
  assignedTickets      CSTicket[]       @relation("TicketAgent")
  customerProfile      CustomerProfile?
  mitraProfile         MitraProfile?
}

model CustomerProfile {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @unique @db.Uuid
  fullName          String
  membershipTier    MembershipTier     @default(SILVER)
  totalPoints       Int                @default(0)
  tierExpiresAt     DateTime?
  avatarUrl         String?
  csTickets         CSTicket[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders            Order[]
  pointTransactions PointTransaction[]
  reviews           ProductReview[]
  voucherClaims     VoucherClaim[]
  warrantyClaims    WarrantyClaim[]
  wishlist          Wishlist[]
}

model MitraProfile {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @unique @db.Uuid
  mitraCode         String             @unique
  showroomName      String
  address           String
  city              String
  latitude          Float
  longitude         Float
  status            MitraStatus        @default(ONBOARDING)
  verifiedAt        DateTime?
  logoUrl           String?
  announcementReads AnnouncementRead[]
  communityLikes    CommunityLike[]
  communityPosts    CommunityPost[]
  communityReplies  CommunityReply[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fulfilledOrders   Order[]
  pointInputs       PointTransaction[] @relation("MitraPointInput")
  products          Product[]
  stockItems        StockPerShowroom[]
}

model Category {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  slug     String     @unique
  icon     String
  parentId String?    @db.Uuid
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku                String             @unique
  name               String
  description        String
  categoryId         String             @db.Uuid
  mitraId            String             @db.Uuid
  price              Int
  originalPrice      Int?
  memberDiscountPct  Int                @default(0)
  pointsPerTxn       Int                @default(0)
  warrantyMonths     Int
  warrantyType       WarrantyType
  insuranceAvailable Boolean            @default(false)
  weightKg           Float
  dimensionsCm       String
  status             ProductStatus      @default(DRAFT)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  orderItems         OrderItem[]
  category           Category           @relation(fields: [categoryId], references: [id])
  mitra              MitraProfile       @relation(fields: [mitraId], references: [id])
  images             ProductImage[]
  reviews            ProductReview[]
  variants           ProductVariant[]
  stockItems         StockPerShowroom[]
  wishlist           Wishlist[]
}

model ProductImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String             @db.Uuid
  size       String?
  color      String?
  colorHex   String?
  priceDelta Int                @default(0)
  skuSuffix  String
  orderItems OrderItem[]
  product    Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockItems StockPerShowroom[]
}

model StockPerShowroom {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String          @db.Uuid
  variantId   String?         @db.Uuid
  mitraId     String          @db.Uuid
  quantity    Int             @default(0)
  minQuantity Int             @default(5)
  updatedAt   DateTime        @updatedAt
  mitra       MitraProfile    @relation(fields: [mitraId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([productId, variantId, mitraId])
}

model Order {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber         String          @unique
  customerId          String          @db.Uuid
  mitraId             String          @db.Uuid
  status              OrderStatus     @default(PENDING)
  totalAmount         Int
  discountAmount      Int             @default(0)
  voucherId           String?         @db.Uuid
  pointsEarned        Int             @default(0)
  pointsUsed          Int             @default(0)
  paymentMethod       String
  installmentProvider String?
  shippingAddress     Json
  notes               String          @default("")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  customer            CustomerProfile @relation(fields: [customerId], references: [id])
  mitra               MitraProfile    @relation(fields: [mitraId], references: [id])
  voucher             Voucher?        @relation(fields: [voucherId], references: [id])
  items               OrderItem[]
  voucherClaims       VoucherClaim[]
}

model OrderItem {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String             @db.Uuid
  productId      String             @db.Uuid
  variantId      String?            @db.Uuid
  quantity       Int
  unitPrice      Int
  subtotal       Int
  insurance      InsuranceCoverage?
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product            @relation(fields: [productId], references: [id])
  variant        ProductVariant?    @relation(fields: [variantId], references: [id])
  review         ProductReview?
  warrantyClaims WarrantyClaim[]
}

model PointTransaction {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId     String               @db.Uuid
  type           PointTransactionType
  amount         Int
  referenceType  PointReferenceType
  referenceId    String?              @db.Uuid
  description    String
  inputByMitraId String?              @db.Uuid
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  customer       CustomerProfile      @relation(fields: [customerId], references: [id])
  inputByMitra   MitraProfile?        @relation("MitraPointInput", fields: [inputByMitraId], references: [id])
}

model Voucher {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String         @unique
  name        String
  type        VoucherType
  value       Int
  minPurchase Int            @default(0)
  maxUses     Int?
  usesPerUser Int            @default(1)
  pointsCost  Int            @default(0)
  validFrom   DateTime
  validUntil  DateTime
  createdAt   DateTime       @default(now())
  orders      Order[]
  claims      VoucherClaim[]
}

model VoucherClaim {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucherId  String          @db.Uuid
  customerId String          @db.Uuid
  usedAt     DateTime?
  orderId    String?         @db.Uuid
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  order      Order?          @relation(fields: [orderId], references: [id])
  voucher    Voucher         @relation(fields: [voucherId], references: [id])

  @@unique([voucherId, customerId])
}

model WarrantyClaim {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId  String              @db.Uuid
  customerId   String              @db.Uuid
  status       WarrantyClaimStatus @default(SUBMITTED)
  description  String
  evidenceUrls Json                @default("[]")
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
  customer     CustomerProfile     @relation(fields: [customerId], references: [id])
  orderItem    OrderItem           @relation(fields: [orderItemId], references: [id])
}

model InsuranceCoverage {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId    String          @unique @db.Uuid
  provider       String
  policyNumber   String
  coverageAmount Int
  expiresAt      DateTime
  status         InsuranceStatus @default(ACTIVE)
  orderItem      OrderItem       @relation(fields: [orderItemId], references: [id])
}

model Announcement {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  content        String
  category       AnnouncementCategory
  priority       AnnouncementPriority @default(NORMAL)
  target         AnnouncementTarget
  targetMitraIds Json?
  attachmentUrl  String?
  publishedAt    DateTime
  createdBy      String               @db.Uuid
  createdAt      DateTime             @default(now())
  creator        User                 @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  reads          AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String       @db.Uuid
  mitraId        String       @db.Uuid
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  mitra          MitraProfile @relation(fields: [mitraId], references: [id])

  @@unique([announcementId, mitraId])
}

model CSTicket {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketNumber    String           @unique
  customerId      String           @db.Uuid
  assignedAgentId String?          @db.Uuid
  subject         String
  status          CSTicketStatus   @default(OPEN)
  priority        CSTicketPriority @default(NORMAL)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  resolvedAt      DateTime?
  messages        CSMessage[]
  assignedAgent   User?            @relation("TicketAgent", fields: [assignedAgentId], references: [id])
  customer        CustomerProfile  @relation(fields: [customerId], references: [id])
}

model CSMessage {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId      String              @db.Uuid
  senderId      String              @db.Uuid
  senderRole    CSMessageSenderRole
  content       String
  attachmentUrl String?
  createdAt     DateTime            @default(now())
  sender        User                @relation(fields: [senderId], references: [id])
  ticket        CSTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mitraId      String              @db.Uuid
  content      String
  tags         Json                @default("[]")
  likesCount   Int                 @default(0)
  repliesCount Int                 @default(0)
  status       CommunityPostStatus @default(ACTIVE)
  createdAt    DateTime            @default(now())
  likes        CommunityLike[]
  mitra        MitraProfile        @relation(fields: [mitraId], references: [id])
  replies      CommunityReply[]
}

model CommunityReply {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String        @db.Uuid
  mitraId   String        @db.Uuid
  content   String
  createdAt DateTime      @default(now())
  mitra     MitraProfile  @relation(fields: [mitraId], references: [id])
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model CommunityLike {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String        @db.Uuid
  mitraId   String        @db.Uuid
  createdAt DateTime      @default(now())
  mitra     MitraProfile  @relation(fields: [mitraId], references: [id])
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, mitraId])
}

model Wishlist {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String          @db.Uuid
  productId  String          @db.Uuid
  createdAt  DateTime        @default(now())
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  product    Product         @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model ProductReview {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId      String          @unique @db.Uuid
  customerId       String          @db.Uuid
  productId        String          @db.Uuid
  rating           Int
  comment          String?
  images           Json            @default("[]")
  verifiedPurchase Boolean         @default(true)
  createdAt        DateTime        @default(now())
  customer         CustomerProfile @relation(fields: [customerId], references: [id])
  orderItem        OrderItem       @relation(fields: [orderItemId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
}

model DailyMetric {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date                   DateTime @unique @db.Date
  gmv                    BigInt   @default(0)
  transactionCount       Int      @default(0)
  newCustomers           Int      @default(0)
  activeCustomers        Int      @default(0)
  openTickets            Int      @default(0)
  avgResponseTimeMinutes Float    @default(0)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_comments {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id             String          @db.Uuid
  user_id             String          @db.Uuid
  parent_comment_id   String?         @db.Uuid
  body                String
  created_at          DateTime        @default(now()) @db.Timestamptz(6)
  edited_at           DateTime?       @db.Timestamptz(6)
  blog_comments       blog_comments?  @relation("blog_commentsToblog_comments", fields: [parent_comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_blog_comments blog_comments[] @relation("blog_commentsToblog_comments")
  blog_posts          blog_posts      @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog_users          blog_users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([post_id], map: "idx_blog_comments_post_id")
  @@index([user_id], map: "idx_blog_comments_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_posts {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String          @db.Uuid
  title         String
  slug          String          @unique
  content       String
  published     Boolean         @default(false)
  published_at  DateTime?       @db.Timestamptz(6)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  blog_comments blog_comments[]
  blog_users    blog_users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([published], map: "idx_blog_posts_published", where: raw("(published = true)"))
  @@index([user_id], map: "idx_blog_posts_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_users {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @unique
  display_name  String
  bio           String?
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  blog_comments blog_comments[]
  blog_posts    blog_posts[]
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  CUSTOMER
  MITRA_USER
  MITRA_ADMIN
  CENTER_ADMIN
}

enum MembershipTier {
  SILVER
  GOLD
  PLATINUM
}

enum MitraStatus {
  ONBOARDING
  REVIEW
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  REVIEW
  ACTIVE
  INACTIVE
}

enum WarrantyType {
  STORE
  MANUFACTURER
  DEXHOME
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  CLAIM
}

enum PointTransactionType {
  EARN
  REDEEM
  BONUS
  EXPIRE
  REFUND
}

enum PointReferenceType {
  ORDER
  VOUCHER
  MANUAL
  CHECKIN
}

enum VoucherType {
  FIXED_DISCOUNT
  PERCENT_DISCOUNT
  FREE_SHIPPING
  CASHBACK
}

enum WarrantyClaimStatus {
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  RESOLVED
}

enum InsuranceStatus {
  ACTIVE
  CLAIMED
  EXPIRED
}

enum AnnouncementCategory {
  PROMO
  SYSTEM
  EVENT
  POLICY
  URGENT
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum AnnouncementTarget {
  ALL_MITRA
  VERIFIED_MITRA
  SPECIFIC
}

enum CSTicketStatus {
  OPEN
  ANSWERED
  RESOLVED
  CLOSED
}

enum CSTicketPriority {
  NORMAL
  HIGH
  URGENT
}

enum CSMessageSenderRole {
  CUSTOMER
  AGENT
}

enum CommunityPostStatus {
  ACTIVE
  HIDDEN
  DELETED
}
