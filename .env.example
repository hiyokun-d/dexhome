# =============================================================================
# DexHome — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL — Supabase or Neon recommended)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dexhome?schema=public"

# If using Supabase with connection pooling (PgBouncer):
# DIRECT_URL="postgresql://user:password@host:5432/dexhome"
# Add directUrl = env("DIRECT_URL") in prisma/schema.prisma datasource block

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js v5)
# -----------------------------------------------------------------------------
AUTH_SECRET=""           # generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# OAuth providers (add only what you use)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# File Storage (Supabase Storage or Cloudflare R2)
# -----------------------------------------------------------------------------
# Option A — Supabase Storage
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""   # server-side only, never expose to client

# Option B — Cloudflare R2 (S3-compatible)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="dexhome-uploads"
# R2_PUBLIC_URL=""               # your public bucket URL

# -----------------------------------------------------------------------------
# Maps
# -----------------------------------------------------------------------------
# Only needed if using Google Maps. Leave empty to use free OpenStreetMap.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# -----------------------------------------------------------------------------
# Real-time / Notifications (pick one)
# -----------------------------------------------------------------------------
# Option A — Pusher (for CS chat real-time)
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER=""
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER=""

# Option B — Supabase Realtime (already included if using Supabase above)

# -----------------------------------------------------------------------------
# Payment Gateway (if ordering is in-app)
# -----------------------------------------------------------------------------
# Midtrans
# MIDTRANS_SERVER_KEY=""
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
# MIDTRANS_IS_PRODUCTION="false"

# Xendit
# XENDIT_SECRET_KEY=""
# NEXT_PUBLIC_XENDIT_PUBLIC_KEY=""

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
